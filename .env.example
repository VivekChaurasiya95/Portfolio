# Backend server
PORT=5000
FRONTEND_ORIGIN=http://localhost:8080
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:5173

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_or_app_password

# Mail routing
MAIL_FROM=your_email@example.com
CONTACT_TARGET_EMAIL=your_email@example.com

# Frontend (only set this when backend is hosted on a different origin)
# Example: VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=
